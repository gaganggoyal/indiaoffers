<%- include('../partials/head') %>
<%- include('../partials/header') %>

<section class="wrap account-page">

  <!-- Hero band -->
  <div class="acc-hero">
    <div class="ah-id">
      <span class="ah-avatar"><%= account.username.slice(0, 1).toUpperCase() %></span>
      <div>
        <h1>Hi, <%= account.username %> 👋</h1>
        <p>Member since <%= String(account.created_at).slice(0, 10) %> · <span class="ah-verified">✓ email verified</span></p>
      </div>
    </div>
    <div class="ah-actions">
      <a class="btn-primary" href="/submit-deal">🎯 Submit a deal</a>
      <form method="post" action="/logout"><button class="btn-ghost ah-logout">Log out</button></form>
    </div>
  </div>

  <% if (welcome) { %><div class="form-ok">🎉 Email verified — welcome to IndiaOffers! Set your cards &amp; categories below to start getting alerts.</div><% } %>
  <% if (saved) { %><div class="form-ok">✓ Preferences saved.</div><% } %>

  <!-- Stat tiles -->
  <% const unread = alerts.filter(a => !a.is_read).length; %>
  <div class="acc-stats">
    <div class="as-tile">
      <span class="as-num">⭐ <%= account.points || 0 %></span>
      <span class="as-lbl">Partner points</span>
      <span class="as-sub">redeem for gifts, vouchers &amp; real money</span>
    </div>
    <div class="as-tile">
      <span class="as-num">🔔 <%= unread %></span>
      <span class="as-lbl">Unread alerts</span>
      <span class="as-sub"><%= alerts.length %> total in your inbox</span>
    </div>
    <div class="as-tile">
      <span class="as-num">🎯 <%= submissionCount %></span>
      <span class="as-lbl">Deals submitted</span>
      <span class="as-sub"><a href="/submit-deal">submit more, earn more →</a></span>
    </div>
    <div class="as-tile">
      <span class="as-num">💳 <%= myBanks.length %></span>
      <span class="as-lbl">Banks followed</span>
      <span class="as-sub">we watch their card sales for you</span>
    </div>
  </div>

  <div class="acc-grid">
    <!-- Alerts -->
    <div class="acc-col">
      <div class="panel-block acc-panel">
        <div class="pb-head">
          <h2>🔔 Your alerts</h2>
          <% if (unread) { %>
            <form method="post" action="/account/alerts/read"><button class="lnk">Mark all read</button></form>
          <% } %>
        </div>
        <% if (alerts.length === 0) { %>
          <div class="acc-empty">
            <span>📭</span>
            <p><b>No alerts yet.</b><br>Add your bank cards and favourite categories in preferences — the moment a sale drops on them, it lands here (and in your email).</p>
          </div>
        <% } else { %>
          <ul class="alert-list">
            <% alerts.forEach(a => { %>
              <li class="alert-item <%= a.is_read ? '' : 'unread' %>">
                <div class="al-body">
                  <b><%= a.title %></b>
                  <p><%= a.body %></p>
                  <% if (a.link_url) { %><a href="<%= a.link_url %>">View offer →</a><% } %>
                </div>
                <span class="al-date"><%= String(a.created_at).slice(0, 10) %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <div class="panel-block acc-panel acc-cta">
        <h2>💰 Earn with IndiaOffers</h2>
        <p class="muted">Found a hot deal anywhere online? Submit it — approved deals earn points you can turn into free gifts, vouchers and real cash.</p>
        <div class="acc-cta-row">
          <a class="btn-primary" href="/submit-deal">Submit a deal →</a>
          <a class="btn-ghost" href="/become-partner">How the partner programme works</a>
        </div>
      </div>
    </div>

    <!-- Preferences -->
    <div class="acc-col">
      <form class="panel-block acc-panel" method="post" action="/account/preferences">
        <h2>⚙️ Preferences</h2>
        <div class="af-grid two">
          <label class="ro">Username<input value="<%= account.username %>" disabled></label>
          <label class="ro">Email<input value="<%= account.email %>" disabled></label>
        </div>
        <label>Mobile number<input name="mobile" value="<%= account.mobile || '' %>" placeholder="10-digit mobile"></label>
        <div class="af-checks">
          <label class="chk"><input type="checkbox" name="whatsapp_optin" <%= account.whatsapp_optin ? 'checked' : '' %>> WhatsApp alerts</label>
          <label class="chk"><input type="checkbox" name="is_bulk_buyer" <%= account.is_bulk_buyer ? 'checked' : '' %>> Bulk / business buyer</label>
        </div>

        <fieldset class="af-fieldset">
          <legend>Interested categories</legend>
          <%- include('../partials/msearch', {
            name: 'categories', placeholder: 'Search categories…', selected: myCats,
            groups: categoryGroups.map(g => ({ label: g.label, options: g.options.map(o => ({ value: o.slug, label: o.icon + ' ' + o.name })) }))
          }) %>
        </fieldset>

        <fieldset class="af-fieldset">
          <legend>Your bank cards</legend>
          <p class="af-hint">Pick your card's <b>bank</b> — we alert you when a sale drops on their cards.</p>
          <%- include('../partials/msearch', {
            name: 'banks', placeholder: 'Search your bank…', selected: myBanks,
            groups: [{ label: 'Banks', options: banks.map(b => ({ value: b, label: '🏦 ' + b })) }]
          }) %>
        </fieldset>

        <button class="btn-primary" type="submit">Save preferences</button>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
