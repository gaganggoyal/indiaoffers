<%- include('_top') %>
<div class="page-bar"><h1>Deals</h1>
  <div class="pb-actions">
    <a class="btn-sec" href="/admin/export/deals.csv">📤 Export CSV</a>
    <a class="btn-sec" href="/admin/import?type=deals">📥 Import CSV</a>
    <a class="btn" href="/admin/deals/new">+ New Deal</a>
  </div>
</div>
<%
  const STATUS_OPTS = [{ v: 'live', l: 'Live' }, { v: 'hidden', l: 'Hidden' }];
  const EXPIRY_OPTS = [{ v: 'active', l: 'Active (not expired)' }, { v: 'soon', l: 'Expiring ≤ 7 days' }, { v: 'expired', l: 'Expired' }, { v: 'none', l: 'No expiry date' }];
%>
<%- include('_filters', { action: '/admin/deals', q: active.q, ph: 'Search deals by title…', selects: [
  { name: 'store',    value: active.store,    all: 'All stores',     options: stores.map(s => ({ v: s.id, l: s.name })) },
  { name: 'category', value: active.category, all: 'All categories', options: categories.map(c => ({ v: c.slug, l: c.name })) },
  { name: 'status',   value: active.status,   all: 'Any status',     options: STATUS_OPTS },
  { name: 'expiry',   value: active.expiry,   all: 'Any expiry',     options: EXPIRY_OPTS }
] }) %>
<div class="panel">
  <table>
    <thead><tr><th>Deal</th><th>Store</th><th>Price</th><th>Badge</th><th>Clicks</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% deals.forEach(d => { %>
        <tr>
          <td><b><%= d.title %></b>
              <% if (d.is_trending) { %><span title="Shown in home page banners">🏠</span><% } %>
              <% if (d.hotness > 0) { %><span title="Hotness — pinned to top of homepage">🔥<%= d.hotness %></span><% } %>
              <br><small class="muted">/deal/<%= d.slug %></small></td>
          <td><%= d.store_name %></td>
          <td><%= d.price != null ? '₹' + Number(d.price).toLocaleString('en-IN') : '—' %>
              <% if (d.mrp) { %><small class="muted"><s>₹<%= Number(d.mrp).toLocaleString('en-IN') %></s></small><% } %></td>
          <td><%= d.badge || '—' %></td>
          <td><%= d.clicks %></td>
          <td><span class="pill <%= d.is_active ? 'ok' : 'off' %>"><%= d.is_active ? 'live' : 'hidden' %></span></td>
          <td class="row-actions">
            <a class="lnk" href="/admin/deals/<%= d.id %>/edit">Edit</a>
            <form method="post" action="/admin/deals/<%= d.id %>/delete" onsubmit="return confirm('Hide this deal?')"><button class="lnk danger">Hide</button></form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_bottom') %>
