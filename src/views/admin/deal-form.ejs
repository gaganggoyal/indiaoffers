<%- include('_top') %>
<div class="page-bar"><h1><%= deal ? 'Edit Deal' : 'New Deal' %></h1>
  <div class="pb-actions">
    <% if (deal) { %><a class="btn btn-ghost" href="/deal/<%= deal.slug %>" target="_blank" rel="noopener">👁 View deal ↗</a><% } %>
    <a class="lnk" href="/admin/deals">← Back</a>
  </div>
</div>
<form class="panel form" method="post" action="/admin/deals/save">
  <% if (deal) { %><input type="hidden" name="id" value="<%= deal.id %>"><% } %>
  <label class="full">Title *<input name="title" required value="<%= deal ? deal.title : '' %>" placeholder="boAt Airdopes 141 TWS Earbuds (42H Playback)"></label>
  <label class="full">URL slug <small>— the deal's web address: indiaoffers.in/deal/<b>your-slug</b>. Leave blank to auto-generate from the title. If the slug is already taken, -2/-3 is appended. ⚠ Changing it on a live deal changes its URL — old links and Google results stop working until re-indexed.</small>
    <input name="slug" value="<%= deal ? deal.slug : '' %>" placeholder="<%= deal ? '' : 'auto-generated from title' %>"></label>
  <label>Store *
    <select name="store_id" required>
      <% stores.forEach(s => { %><option value="<%= s.id %>" <%= deal && deal.store_id === s.id ? 'selected' : '' %>><%= s.name %></option><% }) %>
    </select>
  </label>
  <label>Category
    <select name="category">
      <option value="">— select —</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.slug %>" <%= deal && deal.category === c.slug ? 'selected' : '' %>><%= c.icon %> <%= c.name %></option>
      <% }) %>
    </select>
  </label>
  <label>MRP (₹)<input type="number" step="0.01" name="mrp" value="<%= deal && deal.mrp != null ? deal.mrp : '' %>"></label>
  <label>Deal price (₹)<input type="number" step="0.01" name="price" value="<%= deal && deal.price != null ? deal.price : '' %>"></label>
  <label>Best price override (₹) <small>— blank = show only the deal price</small><input type="number" step="0.01" name="true_price" value="<%= deal && deal.true_price != null ? deal.true_price : '' %>" placeholder="leave blank — no extra savings shown"></label>
  <label class="full">Savings note <small>— optional line shown in the “Extra savings” box (blank = nothing shown)</small><input name="savings_note" value="<%= deal ? (deal.savings_note || '') : '' %>" placeholder="e.g. Extra ₹500 off with SBI cards on orders above ₹3,000"></label>
  <% var srows = []; try { srows = deal && deal.savings_rows ? JSON.parse(deal.savings_rows) : []; } catch (e) { srows = []; } %>
  <div class="full srows-field">
    <label>Extra savings rows <small>— optional. Type your own pay-with-card / coupon options here to show a savings breakdown on this deal. Leave empty and the deal shows only its price — nothing is auto-added.</small></label>
    <table class="srows" id="srows">
      <thead><tr><th>Pay with</th><th>Offer text</th><th>Saves (₹)</th><th>Promo code</th><th></th></tr></thead>
      <tbody>
        <% srows.forEach(r => { %>
          <tr>
            <td><input name="sr_bank[]"   value="<%= r.bank || '' %>"   placeholder="ICICI Amazon Pay CC"></td>
            <td><input name="sr_label[]"  value="<%= r.label || '' %>"  placeholder="10% instant discount, up to ₹500"></td>
            <td><input name="sr_saving[]" value="<%= r.saving || '' %>" type="number" step="1" min="0" placeholder="500"></td>
            <td><input name="sr_promo[]"  value="<%= r.promo || '' %>"  placeholder="optional"></td>
            <td><button type="button" class="sr-del" title="Remove row">✕</button></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <button type="button" class="btn-sec" id="sr-add">+ Add pay option</button>
  </div>
  <label>Coupon code<input name="coupon_code" value="<%= deal ? (deal.coupon_code || '') : '' %>"></label>
  <label>Badge<input name="badge" value="<%= deal ? (deal.badge || '') : '' %>" placeholder="HOT / LOOT / SALE"></label>
  <label>Expiry date<input type="date" name="expiry_date" value="<%= deal && deal.expiry_date ? String(deal.expiry_date).slice(0,10) : '' %>"></label>
  <label>Cashback note<input name="cashback_text" value="<%= deal ? (deal.cashback_text || '') : '' %>" placeholder="Upto 4% IO rewards"></label>
  <label class="full">Video URL (YouTube link, or an uploaded .mp4 path — how this deal works)<input name="video_url" value="<%= deal ? (deal.video_url || '') : '' %>" placeholder="https://www.youtube.com/watch?v=… or /uploads/video.mp4"></label>
  <label class="full">Product image
    <input name="image_url" id="f_deal_image" value="<%= deal ? (deal.image_url || '') : '' %>" placeholder="Paste an image URL, or upload a file below">
    <span class="uploader" data-target="f_deal_image">
      <span class="up-preview"></span>
      <input type="file" accept="image/*" data-upload>
      <span class="up-status"></span>
    </span>
  </label>
  <label class="full">Deal URL (merchant page) *<input name="deal_url" required value="<%= deal ? (deal.deal_url || '') : '' %>" placeholder="https://www.amazon.in/dp/…"></label>
  <label class="full">Description<textarea name="description" rows="3"><%= deal ? (deal.description || '') : '' %></textarea></label>
  <label class="full">How to get it (one step per line)<textarea name="how_to" rows="5"><%= deal ? (JSON.parse(deal.how_to || '[]').join('\n')) : '' %></textarea></label>
  <label>🔥 Hotness <small>— 0 = normal (homepage shows newest deals first). Any number above 0 pins this deal to the top of the homepage grid no matter how old it is; higher number = higher position.</small>
    <input type="number" name="hotness" min="0" step="1" value="<%= deal && deal.hotness ? deal.hotness : 0 %>"></label>
  <label class="check"><input type="checkbox" name="is_trending" <%= deal && deal.is_trending ? 'checked' : '' %>> 🏠 Show in home page banners <small>— ONLY ticked deals appear in the big hero banners on the homepage (3 newest ticked ones); if none are ticked the banner strip is hidden</small></label>
  <label class="check"><input type="checkbox" name="is_active" <%= !deal || deal.is_active ? 'checked' : '' %>> Live on site</label>
  <button class="btn" type="submit"><%= deal ? 'Save changes' : 'Create deal' %></button>
</form>

<% if (deal && typeof stack !== 'undefined' && stack) { %>
  <div class="panel">
    <h2>Extra-savings preview (as visitors see it)<% if (stack.hasSavings) { %> <small style="font-weight:600;color:#0c2b55">— shown</small><% } else { %> <small style="font-weight:600;color:#64748b">— nothing shown (deal price only)</small><% } %></h2>
    <% if (stack.isOverride) { %>
      <p><b>Best price (manual override):</b> ₹<%= (+stack.truePrice).toLocaleString('en-IN') %><% if (stack.mrp) { %> · saves ₹<%= (+stack.maxSaving).toLocaleString('en-IN') %> vs MRP<% } %></p>
    <% } %>
    <% if (stack.savingsNote) { %><p class="muted">Note shown to visitors: “<%= stack.savingsNote %>”</p><% } %>
    <% if (stack.payOptions.length === 0) { %>
      <p class="muted">No extra-savings rows added — this deal shows only its price.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Pay with</th><th>Offer</th><th>Saves</th><th>Effective price</th></tr></thead>
        <tbody>
          <% stack.payOptions.forEach((o, i) => { %>
            <tr class="<%= i === 0 ? 'hl' : '' %>">
              <td><%= o.bank %> <%= o.instrumentLabel %></td>
              <td><%= o.label %></td>
              <td>−₹<%= o.saving.toLocaleString('en-IN') %></td>
              <td><b>₹<%= o.effectivePrice.toLocaleString('en-IN') %></b><%= i === 0 ? ' ← best' : '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
<% } %>

<script>
// "Best way to pay" custom-rows editor: add / remove rows. Each row's inputs use
// [] array names so Express parses them into parallel arrays on submit.
(function () {
  var tbody = document.querySelector('#srows tbody');
  var add   = document.getElementById('sr-add');
  if (!tbody || !add) return;
  function rowHTML() {
    return '<tr>' +
      '<td><input name="sr_bank[]"   placeholder="ICICI Amazon Pay CC"></td>' +
      '<td><input name="sr_label[]"  placeholder="10% instant discount, up to ₹500"></td>' +
      '<td><input name="sr_saving[]" type="number" step="1" min="0" placeholder="500"></td>' +
      '<td><input name="sr_promo[]"  placeholder="optional"></td>' +
      '<td><button type="button" class="sr-del" title="Remove row">✕</button></td>' +
    '</tr>';
  }
  add.addEventListener('click', function () {
    tbody.insertAdjacentHTML('beforeend', rowHTML());
    tbody.lastElementChild.querySelector('input').focus();
  });
  tbody.addEventListener('click', function (e) {
    if (e.target.classList.contains('sr-del')) e.target.closest('tr').remove();
  });
})();
</script>
<%- include('_bottom') %>
