<%- include('_top') %>
<div class="page-bar"><h1><%= deal ? 'Edit Deal' : 'New Deal' %></h1><a class="lnk" href="/admin/deals">← Back</a></div>
<form class="panel form" method="post" action="/admin/deals/save">
  <% if (deal) { %><input type="hidden" name="id" value="<%= deal.id %>"><% } %>
  <label class="full">Title *<input name="title" required value="<%= deal ? deal.title : '' %>" placeholder="boAt Airdopes 141 TWS Earbuds (42H Playback)"></label>
  <label>Store *
    <select name="store_id" required>
      <% stores.forEach(s => { %><option value="<%= s.id %>" <%= deal && deal.store_id === s.id ? 'selected' : '' %>><%= s.name %></option><% }) %>
    </select>
  </label>
  <label>Category
    <select name="category">
      <% ['electronics','fashion','food','beauty','grocery','travel','shopping'].forEach(c => { %>
        <option value="<%= c %>" <%= deal && deal.category === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>
  </label>
  <label>MRP (₹)<input type="number" step="0.01" name="mrp" value="<%= deal && deal.mrp != null ? deal.mrp : '' %>"></label>
  <label>Deal price (₹)<input type="number" step="0.01" name="price" value="<%= deal && deal.price != null ? deal.price : '' %>"></label>
  <label>Coupon code<input name="coupon_code" value="<%= deal ? (deal.coupon_code || '') : '' %>"></label>
  <label>Badge<input name="badge" value="<%= deal ? (deal.badge || '') : '' %>" placeholder="HOT / LOOT / SALE"></label>
  <label>Expiry date<input type="date" name="expiry_date" value="<%= deal && deal.expiry_date ? String(deal.expiry_date).slice(0,10) : '' %>"></label>
  <label>Cashback note<input name="cashback_text" value="<%= deal ? (deal.cashback_text || '') : '' %>" placeholder="Upto 4% IO rewards"></label>
  <label class="full">Image URL<input name="image_url" value="<%= deal ? (deal.image_url || '') : '' %>" placeholder="https://…/product.jpg"></label>
  <label class="full">Deal URL (merchant page) *<input name="deal_url" required value="<%= deal ? (deal.deal_url || '') : '' %>" placeholder="https://www.amazon.in/dp/…"></label>
  <label class="full">Description<textarea name="description" rows="3"><%= deal ? (deal.description || '') : '' %></textarea></label>
  <label class="full">How to get it (one step per line)<textarea name="how_to" rows="5"><%= deal ? (JSON.parse(deal.how_to || '[]').join('\n')) : '' %></textarea></label>
  <label class="check"><input type="checkbox" name="is_trending" <%= deal && deal.is_trending ? 'checked' : '' %>> Trending (featured on homepage)</label>
  <label class="check"><input type="checkbox" name="is_active" <%= !deal || deal.is_active ? 'checked' : '' %>> Live on site</label>
  <button class="btn" type="submit"><%= deal ? 'Save changes' : 'Create deal' %></button>
</form>

<% if (deal && typeof stack !== 'undefined' && stack) { %>
  <div class="panel">
    <h2>Savings stack preview (as visitors see it)</h2>
    <% if (stack.payOptions.length === 0) { %>
      <p class="muted">No bank offers currently apply to this deal (check store, min-order and validity).</p>
    <% } else { %>
      <table>
        <thead><tr><th>Pay with</th><th>Offer</th><th>Saves</th><th>Effective price</th></tr></thead>
        <tbody>
          <% stack.payOptions.forEach((o, i) => { %>
            <tr class="<%= i === 0 ? 'hl' : '' %>">
              <td><%= o.bank %> <%= o.instrumentLabel %></td>
              <td><%= o.label %></td>
              <td>−₹<%= o.saving.toLocaleString('en-IN') %></td>
              <td><b>₹<%= o.effectivePrice.toLocaleString('en-IN') %></b><%= i === 0 ? ' ← best' : '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
<% } %>
<%- include('_bottom') %>
