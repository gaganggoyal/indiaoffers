<%- include('_top') %>
<div class="page-bar"><h1>Bank Offers</h1><a class="btn" href="/admin/bank-offers/new">+ New Offer</a></div>
<% const EXPIRY_OPTS = [{ v: 'active', l: 'Valid (not expired)' }, { v: 'soon', l: 'Expiring ≤ 7 days' }, { v: 'expired', l: 'Expired' }, { v: 'none', l: 'No end date' }]; %>
<%- include('_filters', { action: '/admin/bank-offers', q: active.q, ph: 'Search by offer or bank…', selects: [
  { name: 'store',  value: active.store,  all: 'All stores', options: stores.map(s => ({ v: s.id, l: s.name })) },
  { name: 'status', value: active.status, all: 'Any status', options: [{ v: 'live', l: 'Live' }, { v: 'hidden', l: 'Off' }] },
  { name: 'expiry', value: active.expiry, all: 'Any validity', options: EXPIRY_OPTS }
] }) %>
<div class="panel">
  <table>
    <thead><tr><th>Offer</th><th>Bank</th><th>Discount</th><th>Store</th><th>Valid till</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% offers.forEach(o => { %>
        <tr>
          <td><b><%= o.title %></b></td>
          <td><%= o.bank %> <small class="muted"><%= o.instrument %></small></td>
          <td><%= o.discount_type === 'flat' ? '₹' + o.discount_value : o.discount_value + '%' %><% if (o.max_discount) { %> <small class="muted">cap ₹<%= o.max_discount %></small><% } %></td>
          <td><%= o.store_name || 'All stores' %></td>
          <td><%= o.valid_till ? String(o.valid_till).slice(0,10) : '—' %></td>
          <td><span class="pill <%= o.is_active ? 'ok' : 'off' %>"><%= o.is_active ? 'live' : 'off' %></span></td>
          <td class="row-actions">
            <a class="lnk" href="/admin/bank-offers/<%= o.id %>/edit">Edit</a>
            <form method="post" action="/admin/bank-offers/<%= o.id %>/delete" onsubmit="return confirm('Deactivate this offer?')"><button class="lnk danger">Off</button></form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_bottom') %>
