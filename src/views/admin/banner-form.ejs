<%- include('_top') %>
<div class="page-bar"><h1><%= banner ? 'Edit Banner' : 'New Banner' %></h1><a class="lnk" href="/admin/banners">← Back</a></div>
<form class="panel form" method="post" action="/admin/banners/save">
  <% if (banner) { %><input type="hidden" name="id" value="<%= banner.id %>"><% } %>
  <label class="full">Title *<input name="title" required value="<%= banner ? banner.title : '' %>"></label>
  <label class="full">Subtitle<input name="subtitle" value="<%= banner ? (banner.subtitle || '') : '' %>"></label>
  <label class="full">Image URL (900×500 recommended, blank = colour gradient)<input name="image_url" value="<%= banner ? (banner.image_url || '') : '' %>"></label>
  <label>Background colour<input type="color" name="bg_color" value="<%= banner ? banner.bg_color : '#4f46e5' %>"></label>
  <label>Sort order<input type="number" name="sort_order" value="<%= banner ? banner.sort_order : 0 %>"></label>
  <label class="full">Link URL (e.g. /deal/slug, /bank-offers)<input name="link_url" value="<%= banner ? (banner.link_url || '') : '' %>"></label>
  <label class="check"><input type="checkbox" name="is_active" <%= !banner || banner.is_active ? 'checked' : '' %>> Live on homepage</label>
  <button class="btn" type="submit"><%= banner ? 'Save changes' : 'Create banner' %></button>
</form>
<%- include('_bottom') %>
