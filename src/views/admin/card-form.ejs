<%- include('_top') %>
<div class="page-bar"><h1><%= card ? 'Edit Card' : 'New Card' %></h1><a class="lnk" href="/admin/cards">← Back</a></div>
<form class="panel form" method="post" action="/admin/cards/save">
  <% if (card) { %><input type="hidden" name="id" value="<%= card.id %>"><% } %>
  <label class="full">Card name *<input name="name" required value="<%= card ? card.name : '' %>" placeholder="HDFC Millennia Credit Card"></label>
  <label>Bank *<input name="bank" required value="<%= card ? card.bank : '' %>" placeholder="HDFC Bank"></label>
  <label>Network<input name="network" value="<%= card ? (card.network || '') : '' %>" placeholder="Visa / Mastercard / RuPay / Amex"></label>
  <label>Card type
    <select name="card_type">
      <option value="credit" <%= card && card.card_type === 'credit' ? 'selected' : '' %>>credit</option>
      <option value="debit" <%= card && card.card_type === 'debit' ? 'selected' : '' %>>debit</option>
    </select>
  </label>
  <label>Best for<input name="best_for" value="<%= card ? (card.best_for || '') : '' %>" placeholder="Online shopping & dining"></label>
  <label>Joining fee<input name="joining_fee" value="<%= card ? (card.joining_fee || '') : '' %>" placeholder="₹1,000 + GST"></label>
  <label>Annual fee<input name="annual_fee" value="<%= card ? (card.annual_fee || '') : '' %>" placeholder="₹1,000 (waived on ₹1L spend)"></label>
  <label class="full">Tagline<input name="tagline" value="<%= card ? (card.tagline || '') : '' %>" placeholder="5% cashback on Amazon, Flipkart, Swiggy & more"></label>
  <label class="full">Card art
    <input name="image_url" id="f_card_image" value="<%= card ? (card.image_url || '') : '' %>" placeholder="Paste an image URL, or upload a file below">
    <span class="uploader" data-target="f_card_image">
      <span class="up-preview"></span>
      <input type="file" accept="image/*" data-upload>
      <span class="up-status"></span>
    </span>
  </label>
  <label class="full">Apply URL (affiliate)<input name="apply_url" value="<%= card ? (card.apply_url || '') : '' %>" placeholder="https://…"></label>
  <label class="full">Video URL (YouTube link, or an uploaded .mp4 path — how to apply)<input name="video_url" value="<%= card ? (card.video_url || '') : '' %>" placeholder="https://www.youtube.com/watch?v=… or /uploads/video.mp4"></label>
  <label class="full">Benefits (one per line)<textarea name="benefits" rows="5"><%= card ? JSON.parse(card.benefits || '[]').join('\n') : '' %></textarea></label>
  <label class="full">How to apply — steps (one per line)<textarea name="how_to_apply" rows="4"><%= card ? JSON.parse(card.how_to_apply || '[]').join('\n') : '' %></textarea></label>
  <label class="full">Eligibility<textarea name="eligibility" rows="2"><%= card ? (card.eligibility || '') : '' %></textarea></label>
  <label>Sort order<input type="number" name="sort_order" value="<%= card ? card.sort_order : 0 %>"></label>
  <label class="check"><input type="checkbox" name="is_featured" <%= card && card.is_featured ? 'checked' : '' %>> Featured on homepage</label>
  <label class="check"><input type="checkbox" name="is_active" <%= !card || card.is_active ? 'checked' : '' %>> Live on site</label>
  <button class="btn" type="submit"><%= card ? 'Save changes' : 'Create card' %></button>
</form>
<%- include('_bottom') %>
