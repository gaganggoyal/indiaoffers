<%- include('_top') %>
<div class="page-bar"><h1>Coupons</h1><a class="btn" href="/admin/coupons/new">+ New Coupon</a></div>
<% const EXPIRY_OPTS = [{ v: 'active', l: 'Active (not expired)' }, { v: 'soon', l: 'Expiring ≤ 7 days' }, { v: 'expired', l: 'Expired' }, { v: 'none', l: 'No expiry date' }]; %>
<%- include('_filters', { action: '/admin/coupons', q: active.q, ph: 'Search by code or title…', selects: [
  { name: 'store',    value: active.store,    all: 'All stores', options: stores.map(s => ({ v: s.id, l: s.name })) },
  { name: 'verified', value: active.verified, all: 'Any',        options: [{ v: 'yes', l: 'Verified' }, { v: 'no', l: 'Unverified' }] },
  { name: 'status',   value: active.status,   all: 'Any status', options: [{ v: 'live', l: 'Live' }, { v: 'hidden', l: 'Off' }] },
  { name: 'expiry',   value: active.expiry,   all: 'Any expiry', options: EXPIRY_OPTS }
] }) %>
<div class="panel">
  <table>
    <thead><tr><th>Code</th><th>Title</th><th>Store</th><th>Expiry</th><th>Verified</th><th>Status</th><th></th></tr></thead>
    <tbody>
      <% coupons.forEach(c => { %>
        <tr>
          <td><b class="mono"><%= c.code %></b></td>
          <td><%= c.title %></td>
          <td><%= c.store_name %></td>
          <td><%= c.expiry_date ? String(c.expiry_date).slice(0,10) : '—' %></td>
          <td><%= c.is_verified ? '✅' : '—' %></td>
          <td><span class="pill <%= c.is_active ? 'ok' : 'off' %>"><%= c.is_active ? 'live' : 'off' %></span></td>
          <td class="row-actions">
            <a class="lnk" href="/admin/coupons/<%= c.id %>/edit">Edit</a>
            <form method="post" action="/admin/coupons/<%= c.id %>/delete" onsubmit="return confirm('Deactivate?')"><button class="lnk danger">Off</button></form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_bottom') %>
