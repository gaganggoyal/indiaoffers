<%- include('_top') %>
<div class="page-bar"><h1><%= store ? 'Edit Store' : 'New Store' %></h1><a class="lnk" href="/admin/stores">← Back</a></div>
<form class="panel form" method="post" action="/admin/stores/save">
  <% if (store) { %><input type="hidden" name="id" value="<%= store.id %>"><% } %>
  <label>Name *<input name="name" required value="<%= store ? store.name : '' %>"></label>
  <label>Brand color<input type="color" name="color" value="<%= store ? store.color : '#4f46e5' %>"></label>
  <label>Category
    <select name="category">
      <% ['shopping','electronics','fashion','food','beauty','grocery','travel'].forEach(c => { %>
        <option value="<%= c %>" <%= store && store.category === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>
  </label>
  <label>Affiliate type
    <select name="affiliate_type">
      <% ['none','amazon','flipkart'].forEach(t => { %>
        <option value="<%= t %>" <%= store && store.affiliate_type === t ? 'selected' : '' %>><%= t %></option>
      <% }) %>
    </select>
  </label>
  <label class="full">Website URL *<input name="website_url" required value="<%= store ? (store.website_url || '') : '' %>"></label>
  <label class="full">Affiliate URL (blank = website URL)<input name="affiliate_url" value="<%= store ? (store.affiliate_url || '') : '' %>"></label>
  <label class="full">Affiliate params <small>— query string appended to every outbound link for commission. Overrides the affiliate-type default. Use <code>{click}</code> for the click id.</small>
    <input name="affiliate_params" value="<%= store ? (store.affiliate_params || '') : '' %>" placeholder="tag=indiaoffers0c-21&amp;subid={click}">
  </label>
  <label class="full">Affiliate tracking prefix <small>— network link that the product/deal URL gets <b>attached to the end of</b>. When set, this takes priority over the fields above. Tokens: <code>{click}</code> = our click id (e.g. <code>p1={click}</code>); <code>{username}</code> = the logged-in user, for per-user conversion attribution (e.g. <code>p2={username}</code>, falls back to the click id for guests). Type static values like <code>source=indiaoffers</code> literally. The destination URL is always <b>percent-encoded</b> before it's attached — appended to the end, or into a <code>{url}</code> token if you add one.</small>
    <input name="affiliate_prefix" value="<%= store ? (store.affiliate_prefix || '') : '' %>" placeholder="https://track.vcommission.com/click?campaign_id=13410&amp;pub_id=100668&amp;p1={click}&amp;p2={username}&amp;source=indiaoffers&amp;url=">
  </label>
  <label class="full">Logo
    <input name="logo_url" id="f_store_logo" value="<%= store ? (store.logo_url || '') : '' %>" placeholder="Paste a logo URL, or upload a file below">
    <span class="uploader" data-target="f_store_logo">
      <span class="up-preview"></span>
      <input type="file" accept="image/*" data-upload>
      <span class="up-status"></span>
    </span>
  </label>
  <label>Cashback note<input name="cashback_text" value="<%= store ? (store.cashback_text || '') : '' %>" placeholder="Upto 5% IO rewards"></label>
  <label class="full">Description <small>— shown as an SEO content block below the live deals on the store page. Line breaks &amp; paragraphs are kept exactly as you paste them.</small><textarea name="description" rows="12" style="white-space:pre-wrap"><%= store ? (store.description || '') : '' %></textarea></label>
  <label class="check"><input type="checkbox" name="is_active" <%= !store || store.is_active ? 'checked' : '' %>> Live</label>
  <button class="btn" type="submit"><%= store ? 'Save changes' : 'Create store' %></button>
</form>
<%- include('_bottom') %>
