<%- include('_top') %>
<h1>Dashboard</h1>
<div class="tiles">
  <a class="tile" href="/admin/deals"><b><%= stats.deals %></b><span>Live deals</span></a>
  <a class="tile" href="/admin/bank-offers"><b><%= stats.offers %></b><span>Bank offers</span></a>
  <a class="tile" href="/admin/coupons"><b><%= stats.coupons %></b><span>Coupons</span></a>
  <a class="tile" href="/admin/banners"><b><%= stats.banners %></b><span>Banners</span></a>
  <div class="tile"><b><%= stats.clicks %></b><span>Outbound clicks</span></div>
</div>

<div class="panel">
  <h2>Top deals by clicks</h2>
  <table>
    <thead><tr><th>Deal</th><th style="width:110px">Clicks</th><th style="width:90px"></th></tr></thead>
    <tbody>
      <% topDeals.forEach(d => { %>
        <tr><td><%= d.title %></td><td><%= d.clicks %></td><td><a class="lnk" href="/admin/deals/<%= d.id %>/edit">Edit</a></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_bottom') %>
