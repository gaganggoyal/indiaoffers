<%- include('_top') %>
<h1>Dashboard</h1>
<div class="tiles">
  <a class="tile" href="/admin/deals"><b><%= stats.deals %></b><span>Live deals</span></a>
  <a class="tile" href="/admin/bank-offers"><b><%= stats.offers %></b><span>Bank offers</span></a>
  <a class="tile" href="/admin/cards"><b><%= stats.cards %></b><span>Bank cards</span></a>
  <a class="tile" href="/admin/guides"><b><%= stats.guides %></b><span>Buying guides</span></a>
  <a class="tile" href="/admin/coupons"><b><%= stats.coupons %></b><span>Coupons</span></a>
  <a class="tile" href="/admin/stores"><b><%= stats.stores %></b><span>Stores</span></a>
  <a class="tile" href="/admin/users"><b><%= stats.users %></b><span>Registered users</span></a>
  <div class="tile"><b><%= stats.clicks %></b><span>Outbound clicks</span></div>
</div>

<div class="panel">
  <h2>Top deals by clicks</h2>
  <table>
    <thead><tr><th>Deal</th><th style="width:110px">Clicks</th><th style="width:90px"></th></tr></thead>
    <tbody>
      <% topDeals.forEach(d => { %>
        <tr><td><%= d.title %></td><td><%= d.clicks %></td><td><a class="lnk" href="/admin/deals/<%= d.id %>/edit">Edit</a></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="panel">
  <h2>Offline backup</h2>
  <p class="muted" style="font-size:13px;margin-bottom:12px">
    Downloads one <b>.tar.gz</b> with the full database dump (all deals, stores, users, clicks…)
    plus every image uploaded via the admin panel — everything that isn't already in the GitHub
    repo. The archive includes a README with step-by-step restore instructions, so this file +
    the repo is enough to rebuild the whole site on a new machine.
  </p>
  <a class="btn" href="/admin/backup.tar.gz">⬇️ Download full backup</a>
</div>
<%- include('_bottom') %>
