<%
  // expects: d (decorated deal with .stack), storeMap
  // optional: eager — set on the first couple of cards of a listing page (they
  // can be the mobile LCP element; everything else lazy-loads)
  const eagerImg = typeof eager !== 'undefined' && eager;
  const st = storeMap[d.store_id] || { name: '', color: '#64748b' };
  // Store identity: uploaded logo → site favicon → colour dot (same as deal page)
  const stDomain = ((st.website_url || '').match(/^https?:\/\/([^\/]+)/) || [])[1];
  const stack = d.stack;
  // "Verified" chip only while the human check is fresh (≤ 7 days old)
  const vFresh = d.verified_at && (Date.now() - new Date(String(d.verified_at).replace(' ', 'T')).getTime()) < 7 * 864e5;
%>
<a class="card" href="/deal/<%= d.slug %>">
  <div class="card-img">
    <%# real <img> (not a CSS background) so below-fold cards lazy-load and
        Amazon links get downscaled — admins paste 1500px originals %>
    <% if (d.image_url) { %><img src="<%= thumb(d.image_url, 400) %>" alt="" <%- eagerImg ? 'fetchpriority="high"' : 'loading="lazy"' %> decoding="async"><% } %>
    <% if (stack.discountPct) { %><span class="chip chip-off"><%= stack.discountPct %>% OFF</span><% } %>
    <% if (d.badge) { %><span class="chip chip-badge"><%= d.badge %></span><% } %>
  </div>
  <div class="card-body">
    <div class="card-store">
      <% if (st.logo_url) { %>
        <img class="card-store-logo" src="<%= ver(st.logo_url) %>" alt="" width="16" height="16" loading="lazy">
      <% } else if (stDomain) { %>
        <img class="card-store-logo" src="https://www.google.com/s2/favicons?domain=<%= stDomain %>&sz=64" alt="" width="16" height="16" loading="lazy">
      <% } else { %>
        <i style="background:<%= st.color %>"></i>
      <% } %>
      <%= st.name %><% if (vFresh) { %><span class="card-verified">✅ Verified</span><% } %>
    </div>
    <h3 class="card-title"><%= d.title %></h3>
    <% if (stack.price != null) { %>
      <div class="card-prices">
        <b><%= fmt(stack.price) %></b>
        <% if (stack.mrp != null && stack.mrp > stack.price) { %><s><%= fmt(stack.mrp) %></s><% } %>
      </div>
    <% } %>
    <% if (stack.hasSavings && stack.truePrice != null && stack.truePrice < stack.price) { %>
      <div class="card-true">
        <span class="tp-label">best price</span>
        <b><%= fmt(stack.truePrice) %></b>
        <% if (stack.best && stack.best.bank) { %><span class="tp-with">with <%= stack.best.bank %></span><% } %>
      </div>
    <% } %>
  </div>
</a>
