<%
  // expects: d (decorated deal with .stack), storeMap
  const st = storeMap[d.store_id] || { name: '', color: '#64748b' };
  const stack = d.stack;
%>
<a class="card" href="/deal/<%= d.slug %>">
  <div class="card-img" style="background-image:url('<%= d.image_url || '' %>')">
    <% if (stack.discountPct) { %><span class="chip chip-off"><%= stack.discountPct %>% OFF</span><% } %>
    <% if (d.badge) { %><span class="chip chip-badge"><%= d.badge %></span><% } %>
  </div>
  <div class="card-body">
    <div class="card-store"><i style="background:<%= st.color %>"></i><%= st.name %></div>
    <h3 class="card-title"><%= d.title %></h3>
    <% if (stack.price != null) { %>
      <div class="card-prices">
        <b><%= fmt(stack.price) %></b>
        <% if (stack.mrp != null && stack.mrp > stack.price) { %><s><%= fmt(stack.mrp) %></s><% } %>
      </div>
    <% } %>
    <% if (stack.hasSavings && stack.truePrice != null && stack.truePrice < stack.price) { %>
      <div class="card-true">
        <span class="tp-label">best price</span>
        <b><%= fmt(stack.truePrice) %></b>
        <% if (stack.best && stack.best.bank) { %><span class="tp-with">with <%= stack.best.bank %></span><% } %>
      </div>
    <% } %>
  </div>
</a>
