<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<% if (gaId) { %>
<link rel="preconnect" href="https://www.googletagmanager.com">
<link rel="preconnect" href="https://www.google-analytics.com">
<% } %>
<%# Deal images are hotlinked from Amazon's CDN on most listing pages %>
<link rel="preconnect" href="https://m.media-amazon.com">
<% if (meta && meta.preloadImage) { %>
<%# The LCP hero is a CSS background-image, invisible to the preload scanner —
    without this hint the browser only discovers it after layout (~2s late). %>
<link rel="preload" as="image" href="<%= meta.preloadImage %>" fetchpriority="high">
<% } %>
<% if (gaId) { %>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '<%= gaId %>');
</script>
<% } %>
<title><%= title %></title>
<% if (meta && meta.description) { %><meta name="description" content="<%= meta.description %>"><% } %>
<% if (meta && meta.keywords) { %><meta name="keywords" content="<%= meta.keywords %>"><% } %>
<% if (meta && meta.robots) { %><meta name="robots" content="<%= meta.robots %>"><% } %>
<link rel="canonical" href="<%= siteUrl %><%= (meta && meta.canonical) || path %>">
<%# og:image must be an absolute URL — uploaded images are stored as /uploads/… paths.
    WhatsApp/Facebook skip images over ~600KB, so Amazon-hotlinked originals (often
    1500px+) are downscaled via thumb(). The default banner goes through ver() so a
    regenerated file gets a new URL — WhatsApp caches previews per-URL for weeks. %>
<% const ogDefault = !(meta && meta.image); %>
<% const ogRaw = ogDefault ? ver('/og-image.jpg') : thumb(meta.image, 1200); %>
<% const ogImage = /^https?:\/\//.test(ogRaw) ? ogRaw : siteUrl + ogRaw; %>
<meta property="og:site_name" content="<%= siteName %>">
<meta property="og:type" content="<%= (meta && meta.type) || 'website' %>">
<meta property="og:title" content="<%= title %>">
<% if (meta && meta.description) { %><meta property="og:description" content="<%= meta.description %>"><% } %>
<meta property="og:url" content="<%= siteUrl %><%= (meta && meta.canonical) || path %>">
<meta property="og:image" content="<%= ogImage %>">
<meta property="og:image:alt" content="<%= title %>">
<% if (ogDefault) { %>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:type" content="image/jpeg">
<% } %>
<meta name="twitter:card" content="summary_large_image">
<link rel="icon" type="image/png" href="<%= ver('/img/logo-icon.png') %>">
<link rel="icon" type="image/png" href="<%= ver('/favicon.png') %>">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<!-- Installable PWA (Add to Home Screen) -->
<link rel="manifest" href="/manifest.webmanifest">
<meta name="theme-color" content="#0f172a">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="IndiaOffers">
<% if (meta && meta.jsonld) { %><script type="application/ld+json"><%- JSON.stringify(meta.jsonld) %></script><% } %>
<%# Inlined (not <link>ed) so first paint needs no extra round trip — see siteCss() in app.js %>
<style><%- siteCss() %></style>
</head>
<body>
