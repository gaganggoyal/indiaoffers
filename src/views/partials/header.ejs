<div class="topbar">💡 Handpicked deals with <b>real discounts</b> — plus coupons &amp; card offers across top stores.</div>
<header class="header">
  <div class="header-in">
    <a class="brand" href="/">
      <img src="<%= ver('/img/logo-icon.png') %>" alt="IndiaOffers logo" width="34" height="34">
      <span>India<em>Offers</em>.in</span>
    </a>
    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>
    <form class="search" action="/search" method="get" role="search">
      <input type="search" name="q" value="<%= typeof searchQ !== 'undefined' && searchQ ? searchQ : (typeof active !== 'undefined' && active && active.q ? active.q : '') %>" placeholder="Search deals, products, stores…" autocomplete="off">
      <button type="submit" aria-label="Search">🔍</button>
    </form>
    <nav class="nav" id="site-nav">
      <a href="/deals" class="<%= path.startsWith('/deals') || path.startsWith('/deal/') ? 'on' : '' %>">Deals</a>
      <a href="/loot-deals" class="<%= path === '/loot-deals' ? 'on' : '' %>">🔥 Loot</a>
      <a href="/coupons" class="<%= path === '/coupons' ? 'on' : '' %>">Coupons</a>
      <a href="/bank-offers" class="<%= path.startsWith('/bank-offers') ? 'on' : '' %>">Card Offers</a>
      <a href="/cards" class="<%= path.startsWith('/card') ? 'on' : '' %>">Bank Cards</a>
      <a href="/guides" class="<%= path.startsWith('/guide') ? 'on' : '' %>">Buying Guides</a>
      <a href="/stores" class="<%= path.startsWith('/store') ? 'on' : '' %>">Stores</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/account" class="acct <%= path.startsWith('/account') ? 'on' : '' %>">👤 <%= user.username %></a>
      <% } else { %>
        <a href="/register" class="acct <%= path === '/login' || path === '/register' ? 'on' : '' %>">✨ Register</a>
      <% } %>
    </nav>
  </div>
</header>
<%# Collapse the mobile nav before first paint — doing this from site.js (loaded
    at the end of body) let the stacked nav render first, then vanish, shifting
    the whole page up (CLS ~0.4 on mobile). No-JS browsers skip this and keep
    the stacked, fully usable nav. %>
<script>document.querySelector('.header').classList.add('js-nav');</script>
