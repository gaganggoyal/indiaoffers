<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Hero: up to 3 admin-picked banner deals; hidden when none are ticked -->
<% if (heroDeals.length) { %>
<section class="wrap">
  <div class="hero-row">
    <% heroDeals.forEach((d, i) => { const st = storeMap[d.store_id] || { name: '', color: '#4f46e5' }; %>
      <a class="hero-banner" href="/deal/<%= d.slug %>"
         style="--sc:<%= st.color %>">
        <div class="hb-img" style="background-image:url('<%= d.image_url || '' %>')"></div>
        <div class="hb-shade"></div>
        <div class="hb-txt">
          <span class="hb-tag"><%= d.badge || 'JUST IN' %> · <%= st.name %></span>
          <h2><%= d.title %></h2>
          <div class="hb-price">
            <% if (d.stack.price != null) { %><b><%= fmt(d.stack.price) %></b><% } %>
            <% if (d.stack.mrp && d.stack.mrp > d.stack.price) { %><s><%= fmt(d.stack.mrp) %></s><% } %>
            <% if (d.stack.discountPct) { %><span class="hb-off"><%= d.stack.discountPct %>% OFF</span><% } %>
          </div>
          <% if (d.stack.hasSavings && d.stack.truePrice != null && d.stack.truePrice < d.stack.price) { %><span class="hb-true">Best price <%= fmt(d.stack.truePrice) %><% if (d.stack.best && d.stack.best.bank) { %> with <%= d.stack.best.bank %><% } %></span><% } %>
          <span class="hb-cta">Grab this deal →</span>
        </div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- Hot zones — high-intent SEO landing pages -->
<section class="wrap">
  <div class="sec-head"><h2>⚡ Hot Zones</h2></div>
  <div class="zone-chips">
    <% collections.forEach(c => { %>
      <a class="zc" href="/<%= c.slug %>"><%= c.emoji %> <%= c.nav %></a>
    <% }) %>
  </div>
</section>

<!-- Categories — top-level departments only -->
<section class="wrap">
  <div class="sec-head"><h2>🧭 Shop by Category</h2><a href="/deals">All deals →</a></div>
  <div class="cat-grid">
    <% categoryTree.forEach(dept => { %>
      <a class="cat-tile" href="/deals?category=<%= dept.slug %>">
        <span class="cat-ico"><%= dept.icon %></span>
        <span class="cat-name"><%= dept.name %></span>
      </a>
    <% }) %>
  </div>
</section>

<!-- Deals grid -->
<section class="wrap">
  <div class="sec-head"><h2>🔥 Today's Best Deals</h2><a href="/deals">All deals →</a></div>
  <div class="grid">
    <% deals.forEach(d => { %><%- include('partials/deal-card', { d, storeMap }) %><% }) %>
  </div>
</section>

<!-- Apply for bank cards -->
<% if (featuredCards && featuredCards.length) { %>
<section class="wrap">
  <div class="sec-head"><h2>🏦 Best Cards to Apply For</h2><a href="/cards">Compare all cards →</a></div>
  <div class="offer-row">
    <% featuredCards.forEach(c => { %>
      <a class="offer-card" href="/card/<%= c.slug %>">
        <div class="oc-bank"><%= c.bank %> <span><%= c.card_type.toUpperCase() %></span></div>
        <div class="oc-title"><%= c.name %></div>
        <div class="oc-meta"><%= c.tagline || c.best_for || '' %></div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
