<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Hero: 3 top recent deals as banners -->
<section class="wrap">
  <div class="hero-row">
    <% heroDeals.forEach((d, i) => { const st = storeMap[d.store_id] || { name: '', color: '#4f46e5' }; %>
      <a class="hero-banner" href="/deal/<%= d.slug %>"
         style="--sc:<%= st.color %>">
        <div class="hb-img" style="background-image:url('<%= d.image_url || '' %>')"></div>
        <div class="hb-shade"></div>
        <div class="hb-txt">
          <span class="hb-tag"><%= d.badge || 'JUST IN' %> · <%= st.name %></span>
          <h2><%= d.title %></h2>
          <div class="hb-price">
            <% if (d.stack.price != null) { %><b><%= fmt(d.stack.price) %></b><% } %>
            <% if (d.stack.mrp && d.stack.mrp > d.stack.price) { %><s><%= fmt(d.stack.mrp) %></s><% } %>
            <% if (d.stack.discountPct) { %><span class="hb-off"><%= d.stack.discountPct %>% OFF</span><% } %>
          </div>
          <% if (d.stack.best) { %><span class="hb-true">True price <%= fmt(d.stack.truePrice) %> with <%= d.stack.best.bank %></span><% } %>
          <span class="hb-cta">Grab this deal →</span>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<!-- How the stack works -->
<section class="wrap">
  <div class="stackline">
    <span class="sl-item">🏷️ Product discount</span><span class="sl-plus">+</span>
    <span class="sl-item">💳 Your card's offer</span><span class="sl-plus">+</span>
    <span class="sl-item">🎟️ Coupon code</span><span class="sl-eq">=</span>
    <span class="sl-item sl-final">✅ The true price</span>
  </div>
</section>

<!-- Categories — department → sub-group → leaf tree -->
<section class="wrap">
  <div class="sec-head"><h2>🧭 Shop by Category</h2><a href="/deals">All deals →</a></div>
  <div class="cat-tree">
    <% categoryTree.forEach(dept => { %>
      <div class="ct-dept">
        <a class="ct-dept-head" href="/deals?category=<%= dept.slug %>"><span><%= dept.icon %></span><%= dept.name %></a>
        <% dept.children.forEach(grp => { %>
          <div class="ct-grp">
            <a class="ct-grp-head" href="/deals?category=<%= grp.slug %>"><%= grp.name %></a>
            <div class="ct-leaves">
              <% grp.children.forEach(leaf => { %>
                <a class="ct-leaf" href="/deals?category=<%= leaf.slug %>"><%= leaf.icon %> <%= leaf.name %></a>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    <% }) %>
  </div>
</section>

<!-- Card offers strip -->
<section class="wrap">
  <div class="sec-head"><h2>💳 This Week's Card Offers</h2><a href="/bank-offers">All bank offers →</a></div>
  <div class="offer-row">
    <% topOffers.forEach(o => { const st = o.store_id ? storeMap[o.store_id] : null; %>
      <a class="offer-card" href="/bank-offers?bank=<%= encodeURIComponent(o.bank) %>">
        <div class="oc-bank"><%= o.bank %> <span><%= o.instrument.toUpperCase() %></span></div>
        <div class="oc-title"><%= o.title %></div>
        <div class="oc-meta">
          <%= st ? 'On ' + st.name : 'On all stores' %>
          <% if (o.max_discount) { %> · save up to <%= fmt(o.max_discount) %><% } %>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<!-- Deals grid -->
<section class="wrap">
  <div class="sec-head"><h2>🔥 Today's Best Deals</h2><a href="/deals">All deals →</a></div>
  <div class="grid">
    <% deals.forEach(d => { %><%- include('partials/deal-card', { d, storeMap }) %><% }) %>
  </div>
</section>

<!-- Apply for bank cards -->
<% if (featuredCards && featuredCards.length) { %>
<section class="wrap">
  <div class="sec-head"><h2>🏦 Best Cards to Apply For</h2><a href="/cards">Compare all cards →</a></div>
  <div class="offer-row">
    <% featuredCards.forEach(c => { %>
      <a class="offer-card" href="/card/<%= c.slug %>">
        <div class="oc-bank"><%= c.bank %> <span><%= c.card_type.toUpperCase() %></span></div>
        <div class="oc-title"><%= c.name %></div>
        <div class="oc-meta"><%= c.tagline || c.best_for || '' %></div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
