<%- include('partials/head') %>
<%- include('partials/header') %>

<% if (typeof welcome !== 'undefined' && welcome && typeof user !== 'undefined' && user) { %>
<section class="wrap">
  <div class="welcome-strip">
    <span class="ws-txt">🎉 <b>Welcome, <%= user.username %>!</b> You're all set — grab a deal below, and tap <b>👤 <%= user.username %></b> in the menu anytime for your alerts, points &amp; preferences.</span>
    <a class="ws-btn" href="/account">View my profile →</a>
  </div>
</section>
<% } %>

<!-- Hero: up to 3 slots — admin image banners first, then ticked deals/guides -->
<% if (heroItems.length) { %>
<section class="wrap">
  <div class="hero-row">
    <% heroItems.forEach(item => { %>
      <% if (item.type === 'banner') { const b = item.b; %>
        <% if (b.image_url) { %>
          <!-- ready-made creative: the image IS the banner, whole thing clicks through -->
          <a class="hero-banner hb-pure" href="<%= b.link_url || '#' %>" aria-label="<%= b.title %>">
            <div class="hb-img" style="background-image:url('<%= b.image_url %>')"></div>
          </a>
        <% } else { %>
          <a class="hero-banner" href="<%= b.link_url || '#' %>" style="--sc:<%= b.bg_color || '#4f46e5' %>">
            <div class="hb-img" style="background:linear-gradient(135deg, <%= b.bg_color || '#4f46e5' %>, #1e1b4b)"></div>
            <div class="hb-shade"></div>
            <div class="hb-txt">
              <h2><%= b.title %></h2>
              <% if (b.subtitle) { %><div class="hb-price"><span class="hb-sub"><%= b.subtitle %></span></div><% } %>
              <span class="hb-cta">Check it out →</span>
            </div>
          </a>
        <% } %>
      <% } else if (item.type === 'deal') { const d = item.d; const st = storeMap[d.store_id] || { name: '', color: '#4f46e5' }; %>
        <a class="hero-banner" href="/deal/<%= d.slug %>"
           style="--sc:<%= st.color %>">
          <div class="hb-img" style="background-image:url('<%= thumb(d.image_url, 800) || '' %>')"></div>
          <div class="hb-shade"></div>
          <div class="hb-txt">
            <span class="hb-tag"><%= d.badge || 'JUST IN' %> · <%= st.name %></span>
            <h2><%= d.title %></h2>
            <div class="hb-price">
              <% if (d.stack.price != null) { %><b><%= fmt(d.stack.price) %></b><% } %>
              <% if (d.stack.mrp && d.stack.mrp > d.stack.price) { %><s><%= fmt(d.stack.mrp) %></s><% } %>
              <% if (d.stack.discountPct) { %><span class="hb-off"><%= d.stack.discountPct %>% OFF</span><% } %>
            </div>
            <% if (d.stack.hasSavings && d.stack.truePrice != null && d.stack.truePrice < d.stack.price) { %><span class="hb-true">Best price <%= fmt(d.stack.truePrice) %><% if (d.stack.best && d.stack.best.bank) { %> with <%= d.stack.best.bank %><% } %></span><% } %>
            <span class="hb-cta">Grab this deal →</span>
          </div>
        </a>
      <% } else { const g = item.g; %>
        <a class="hero-banner" href="/guide/<%= g.slug %>" style="--sc:#7c3aed">
          <div class="hb-img" style="background-image:url('<%= thumb(g.hero_image, 800) || '' %>')"></div>
          <div class="hb-shade"></div>
          <div class="hb-txt">
            <span class="hb-tag">📖 BUYING GUIDE</span>
            <h2><%= g.title %></h2>
            <% if (g.subtitle) { %><div class="hb-price"><span class="hb-sub"><%= g.subtitle %></span></div><% } %>
            <span class="hb-cta">Read the guide →</span>
          </div>
        </a>
      <% } %>
    <% }) %>
  </div>
</section>
<% } %>

<!-- Hot zones — high-intent SEO landing pages -->
<section class="wrap">
  <div class="sec-head"><h2>⚡ Hot Zones</h2></div>
  <div class="zone-chips">
    <% collections.forEach(c => { %>
      <a class="zc" href="/<%= c.slug %>"><%= c.emoji %> <%= c.nav %></a>
    <% }) %>
  </div>
</section>

<!-- Categories — top-level departments only -->
<section class="wrap">
  <div class="sec-head"><h2>🧭 Shop by Category</h2><a href="/deals">All deals →</a></div>
  <div class="cat-grid">
    <% categoryTree.forEach(dept => { %>
      <a class="cat-tile" href="/category/<%= dept.slug %>">
        <span class="cat-ico"><%= dept.icon %></span>
        <span class="cat-name"><%= dept.name %></span>
      </a>
    <% }) %>
  </div>
</section>

<!-- Deals grid -->
<section class="wrap" id="deals">
  <div class="sec-head"><h2>🔥 Today's Best Deals</h2><a href="/deals">All deals →</a></div>
  <div class="grid">
    <% deals.forEach(d => { %><%- include('partials/deal-card', { d, storeMap }) %><% }) %>
  </div>
  <% if (pagination.totalPages > 1) {
       const cur = pagination.page, last = pagination.totalPages;
       const pageUrl = n => '/' + (n > 1 ? '?page=' + n : '') + '#deals'; %>
  <nav class="pager" aria-label="Deal pages">
    <% if (cur > 1) { %><a class="pg" href="<%= pageUrl(cur - 1) %>" rel="prev">← Prev</a><% } %>
    <% for (let n = 1; n <= last; n++) {
         if (n === 1 || n === last || (n >= cur - 1 && n <= cur + 1)) { %>
      <a class="pg <%= n === cur ? 'on' : '' %>" href="<%= pageUrl(n) %>"><%= n %></a>
    <%   } else if (n === cur - 2 || n === cur + 2) { %>
      <span class="pg-gap">…</span>
    <%   } } %>
    <% if (cur < last) { %><a class="pg" href="<%= pageUrl(cur + 1) %>" rel="next">Next →</a><% } %>
  </nav>
  <% } %>
</section>

<!-- Apply for bank cards -->
<% if (featuredCards && featuredCards.length) { %>
<section class="wrap">
  <div class="sec-head"><h2>🏦 Best Cards to Apply For</h2><a href="/cards">Compare all cards →</a></div>
  <div class="offer-row">
    <% featuredCards.forEach(c => { %>
      <a class="offer-card" href="/card/<%= c.slug %>">
        <div class="oc-bank"><%= c.bank %> <span><%= c.card_type.toUpperCase() %></span></div>
        <div class="oc-title"><%= c.name %></div>
        <div class="oc-meta"><%= c.tagline || c.best_for || '' %></div>
      </a>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
