<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="wrap">
  <nav class="crumbs"><a href="/">Home</a> / <a href="/deals">Deals</a> / <% if (deal.category) { %><a href="/category/<%= deal.category %>"><%= categoryName ? categoryName(deal.category) : deal.category %></a> / <% } %><span><%= deal.title %></span></nav>

  <% if (expired) { %>
    <div class="deal-expired">
      ⌛ <b>This deal has expired.</b> Prices move fast — the fresh <%= store ? store.name : '' %> deals below are live right now<% if (deal.category) { %>, or browse today's <a href="/category/<%= deal.category %>">best <%= categoryName ? categoryName(deal.category).toLowerCase() : '' %> deals</a><% } %>.
    </div>
  <% } %>

  <%# No image (e.g. a giveaway or a service offer) → drop the media column and
      go full-width, rather than rendering <img src=""> which browsers resolve
      to the page URL itself and re-request. %>
  <div class="dd<%= deal.image_url ? '' : ' dd-noimg' %>">
    <% if (deal.image_url) { %>
      <div class="dd-media">
        <%# LCP element of the deal page — never lazy-load it %>
        <img src="<%= thumb(deal.image_url, 800) %>" alt="<%= deal.title %>" fetchpriority="high">
      </div>
    <% } %>

    <div class="dd-main">
      <%# Store identity: uploaded logo → site favicon → colour dot fallback %>
      <% const storeSite = store.website_url || ''; const storeDomain = (storeSite.match(/^https?:\/\/([^\/]+)/) || [])[1]; %>
      <a class="dd-store" href="/store/<%= store.slug %>">
        <% if (store.logo_url) { %>
          <img class="dd-store-logo" src="<%= ver(store.logo_url) %>" alt="" width="20" height="20">
        <% } else if (storeDomain) { %>
          <img class="dd-store-logo" src="https://www.google.com/s2/favicons?domain=<%= storeDomain %>&sz=64" alt="" width="20" height="20" loading="lazy">
        <% } else { %>
          <i style="background:<%= store.color %>"></i>
        <% } %>
        <%= store.name %>
      </a>
      <h1><%= deal.title %></h1>

      <% if (stack.price != null) { %>
        <div class="dd-prices">
          <b class="dd-price"><%= fmt(stack.price) %></b>
          <% if (stack.mrp != null && stack.mrp > stack.price) { %>
            <s><%= fmt(stack.mrp) %></s>
            <span class="chip chip-off"><%= stack.discountPct %>% OFF</span>
          <% } %>
        </div>
      <% } %>

      <% if (deal.coupon_code) { %>
        <div class="codebox">
          <div><small>COUPON CODE</small><b class="code" id="dealCode"><%= deal.coupon_code %></b></div>
          <button class="btn-copy" data-code="<%= deal.coupon_code %>">Copy</button>
        </div>
      <% } %>

      <!-- Grab button just below the price, then a single "How to get this deal"
           card. Extra savings (when the admin added them) live INSIDE this card
           rather than in a separate box. -->
      <div class="dd-action">
        <div class="dd-grab">
          <% if (expired) { %>
            <a class="btn-go btn-go-expired" href="/store/<%= store.slug %>">Deal expired — see live <%= store.name %> deals →</a>
          <% } else { %>
            <a class="btn-go" href="/go/d/<%= deal.id %>" target="_blank" rel="noopener nofollow">Grab this deal at <%= store.name %> →</a>
          <% } %>
          <div class="dd-meta">
            <% if (!expired) { %>⏰ Expires <%= deal.expiry_date ? String(deal.expiry_date).slice(0,10) : 'soon' %>
            · <% } %>👆 <%= (deal.clicks || 0).toLocaleString('en-IN') %> clicks
            <% if (deal.cashback_text) { %> · 💰 <%= deal.cashback_text %><% } %>
          </div>
          <div class="dd-trust">
            <% if (deal.verified_at) { %>✅ Last verified <%= String(deal.verified_at).slice(0,10) %> · <% } %><a href="/how-we-verify">How we verify deals</a>
          </div>
        </div>

        <div class="dd-howto">
          <div class="dd-howto-h">📋 How to get this deal</div>
          <ol class="steps">
            <%# First step is always the same; any admin-entered steps follow it. %>
            <li>Click on <b>Grab this Deal at <%= store.name %></b>.</li>
            <% howTo.forEach(s => { %><li><%= s %></li><% }) %>
            <%# Extra savings are woven in as the next steps (2nd/3rd point) rather than a separate box %>
            <% if (stack.savingsNote) { %><li><%= stack.savingsNote %></li><% } %>
            <% stack.payOptions.forEach(o => { %>
              <li>Pay with <b><%= o.bank %></b> to get <%= o.label %><%= o.promoCode ? ` (use code ${o.promoCode})` : '' %> — effective price <b class="hi-price"><%= fmt(o.effectivePrice) %></b>.</li>
            <% }) %>
            <% if (stack.isOverride && stack.payOptions.length === 0) { %>
              <li>With the current offers, your effective price comes to about <b class="hi-price"><%= fmt(stack.truePrice) %></b>.</li>
            <% } %>
          </ol>
        </div>
      </div>

    </div>
  </div>

  <% if (deal.video_url) { %>
    <div class="panel">
      <h2>🎬 Watch: how this deal works</h2>
      <div class="video-wrap">
        <% const vm = String(deal.video_url).match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]{6,})/); %>
        <% if (vm) { %>
          <iframe src="https://www.youtube.com/embed/<%= vm[1] %>" title="How this deal works" allowfullscreen loading="lazy"></iframe>
        <% } else if (/\.(mp4|webm)(\?|$)/i.test(deal.video_url)) { %>
          <video src="<%= deal.video_url %>" controls playsinline preload="metadata"></video>
        <% } else { %>
          <a href="<%= deal.video_url %>" target="_blank" rel="noopener">▶ Watch how this deal works</a>
        <% } %>
      </div>
    </div>
  <% } %>

  <% if (deal.description) { %>
    <div class="panel"><h2>ℹ️ About this deal</h2><div class="deal-desc"><%- richText(deal.description) %></div></div>
  <% } %>

  <% if (coupons.length) { %>
    <div class="panel">
      <h2>🎟️ More <%= store.name %> coupons</h2>
      <div class="coupon-list">
        <% coupons.forEach(c => { %>
          <div class="coupon">
            <div><b><%= c.title %></b><small><%= c.discount_text %><%= c.min_order ? ` · min order ${fmt(c.min_order)}` : '' %><%= c.is_verified ? ' · ✅ verified' : '' %></small></div>
            <button class="btn-copy" data-code="<%= c.code %>"><%= c.code %></button>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (related.length) { %>
    <div class="sec-head" style="margin-top:34px"><h2>More from <%= store.name %></h2><a href="/store/<%= store.slug %>">View store →</a></div>
    <div class="grid grid-sm">
      <% related.forEach(d => { %><%- include('partials/deal-card', { d, storeMap }) %><% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
