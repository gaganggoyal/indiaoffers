<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="wrap">
  <nav class="crumbs"><a href="/">Home</a> / <a href="/deals">Deals</a> / <span><%= deal.title %></span></nav>

  <div class="dd">
    <div class="dd-media">
      <img src="<%= deal.image_url || '' %>" alt="<%= deal.title %>" loading="lazy">
    </div>

    <div class="dd-main">
      <a class="dd-store" href="/store/<%= store.slug %>"><i style="background:<%= store.color %>"></i><%= store.name %></a>
      <h1><%= deal.title %></h1>

      <% if (stack.price != null) { %>
        <div class="dd-prices">
          <b class="dd-price"><%= fmt(stack.price) %></b>
          <% if (stack.mrp != null && stack.mrp > stack.price) { %>
            <s><%= fmt(stack.mrp) %></s>
            <span class="chip chip-off"><%= stack.discountPct %>% OFF</span>
          <% } %>
        </div>
      <% } %>

      <% if (deal.coupon_code) { %>
        <div class="codebox">
          <div><small>COUPON CODE</small><b class="code" id="dealCode"><%= deal.coupon_code %></b></div>
          <button class="btn-copy" data-code="<%= deal.coupon_code %>">Copy</button>
        </div>
      <% } %>

      <!-- Grab button just below the price, then a single "How to get this deal"
           card. Extra savings (when the admin added them) live INSIDE this card
           rather than in a separate box. -->
      <div class="dd-action">
        <div class="dd-grab">
          <a class="btn-go" href="/go/d/<%= deal.id %>" target="_blank" rel="noopener nofollow">Grab this deal at <%= store.name %> →</a>
          <div class="dd-meta">
            ⏰ Expires <%= deal.expiry_date ? String(deal.expiry_date).slice(0,10) : 'soon' %>
            · 👆 <%= (deal.clicks || 0).toLocaleString('en-IN') %> clicks
            <% if (deal.cashback_text) { %> · 💰 <%= deal.cashback_text %><% } %>
          </div>
        </div>

        <div class="dd-howto">
          <div class="dd-howto-h">📋 How to get this deal</div>
          <ol class="steps">
            <%# First step is always the same; any admin-entered steps follow it. %>
            <li>Click on <b>Grab this Deal at <%= store.name %></b>.</li>
            <% howTo.forEach(s => { %><li><%= s %></li><% }) %>
            <%# Extra savings are woven in as the next steps (2nd/3rd point) rather than a separate box %>
            <% if (stack.savingsNote) { %><li><%= stack.savingsNote %></li><% } %>
            <% stack.payOptions.forEach(o => { %>
              <li>Pay with <b><%= o.bank %></b> to get <%= o.label %><%= o.promoCode ? ` (use code ${o.promoCode})` : '' %> — effective price <b class="hi-price"><%= fmt(o.effectivePrice) %></b>.</li>
            <% }) %>
            <% if (stack.isOverride && stack.payOptions.length === 0) { %>
              <li>With the current offers, your effective price comes to about <b class="hi-price"><%= fmt(stack.truePrice) %></b>.</li>
            <% } %>
          </ol>
        </div>
      </div>

    </div>
  </div>

  <% if (deal.description) { %>
    <div class="panel"><h2>ℹ️ About this deal</h2><div class="deal-desc"><%- richText(deal.description) %></div></div>
  <% } %>

  <% if (coupons.length) { %>
    <div class="panel">
      <h2>🎟️ More <%= store.name %> coupons</h2>
      <div class="coupon-list">
        <% coupons.forEach(c => { %>
          <div class="coupon">
            <div><b><%= c.title %></b><small><%= c.discount_text %><%= c.min_order ? ` · min order ${fmt(c.min_order)}` : '' %><%= c.is_verified ? ' · ✅ verified' : '' %></small></div>
            <button class="btn-copy" data-code="<%= c.code %>"><%= c.code %></button>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (related.length) { %>
    <div class="sec-head" style="margin-top:34px"><h2>More from <%= store.name %></h2><a href="/store/<%= store.slug %>">View store →</a></div>
    <div class="grid">
      <% related.forEach(d => { %><%- include('partials/deal-card', { d, storeMap }) %><% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
