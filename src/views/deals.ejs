<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="wrap">
  <div class="page-head">
    <h1><%= active.q ? `Deals matching “${active.q}”` : catName ? `${catName} Deals` : "Today's Best Deals" %></h1>
    <p>Handpicked deals with real discounts, working coupons and card offers.</p>
  </div>

  <!-- Top-level departments only — clean, matches the homepage -->
  <div class="filters">
    <a class="f <%= !active.category ? 'on' : '' %>" href="/deals">All</a>
    <% categoryTree.forEach(dept => { %>
      <a class="f <%= activeDept === dept.slug ? 'on' : '' %>" href="/category/<%= dept.slug %>"><%= dept.icon %> <%= dept.name %></a>
    <% }) %>
  </div>

  <% if (deals.length === 0) { %>
    <div class="empty">No deals found<%= active.q ? ` for “${active.q}”` : '' %>. <a href="/deals">See all deals</a></div>
  <% } else { %>
    <% if (fallback) { %>
      <div class="fallback-note">No live deals in <b><%= catName || 'this search' %></b> right now — here are today's top deals instead.</div>
    <% } %>
    <div class="grid">
      <% deals.forEach((d, i) => { %><%- include('partials/deal-card', { d, storeMap, eager: i < 2 }) %><% }) %>
    </div>

    <% if (!fallback && pagination.totalPages > 1) {
         const pageUrl = n => { const u = new URLSearchParams();
           if (active.category) u.set('category', active.category);
           if (active.store) u.set('store', active.store);
           if (active.q) u.set('q', active.q);
           if (n > 1) u.set('page', n);
           const s = u.toString(); return '/deals' + (s ? '?' + s : ''); };
         const cur = pagination.page, last = pagination.totalPages; %>
      <nav class="pager" aria-label="Deal pages">
        <% if (cur > 1) { %><a class="pg" href="<%= pageUrl(cur - 1) %>" rel="prev">← Prev</a><% } %>
        <% for (let n = 1; n <= last; n++) {
             if (n === 1 || n === last || (n >= cur - 1 && n <= cur + 1)) { %>
          <a class="pg <%= n === cur ? 'on' : '' %>" href="<%= pageUrl(n) %>"><%= n %></a>
        <%   } else if (n === cur - 2 || n === cur + 2) { %>
          <span class="pg-gap">…</span>
        <%   } } %>
        <% if (cur < last) { %><a class="pg" href="<%= pageUrl(cur + 1) %>" rel="next">Next →</a><% } %>
      </nav>
    <% } %>
  <% } %>
</section>

<%- include('partials/footer') %>
