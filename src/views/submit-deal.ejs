<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="wrap">
  <div class="page-head" style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap">
    <div>
      <h1>Submit a Deal 🎯</h1>
      <p>Found a loot? Share it — approved deals earn you points redeemable for gifts, vouchers &amp; real money.</p>
    </div>
    <span class="points-pill">⭐ Your points: <%= points %></span>
  </div>

  <form class="contact-form submit-card" method="post" action="/submit-deal">
    <% if (sent) { %><div class="form-ok">✓ Deal submitted! Our team will review it shortly — points are credited the moment it's approved.</div><% } %>
    <% if (error) { %><div class="form-err"><%= error %></div><% } %>
    <label>Product / deal title *<input name="title" required maxlength="300" value="<%= form.title || '' %>" placeholder="e.g. boAt Airdopes 141 at ₹999 (MRP ₹4,490)"></label>
    <label>Deal link *<input type="url" name="deal_url" required maxlength="1000" value="<%= form.deal_url || '' %>" placeholder="https://www.amazon.in/dp/…"></label>
    <div class="cf-two">
      <label>Deal price (₹)<input type="number" step="0.01" min="0" name="price" value="<%= form.price || '' %>" placeholder="999"></label>
      <label>MRP (₹)<input type="number" step="0.01" min="0" name="mrp" value="<%= form.mrp || '' %>" placeholder="4490"></label>
    </div>
    <div class="cf-two">
      <label>Store<input name="store_name" maxlength="120" value="<%= form.store_name || '' %>" placeholder="Amazon / Flipkart / Myntra…"></label>
      <label>Coupon code (if any)<input name="coupon_code" maxlength="80" value="<%= form.coupon_code || '' %>" placeholder="optional"></label>
    </div>
    <label>Why is it a great deal? <small>— price history, coupon stack, card offer… anything that helps us verify faster</small><textarea name="note" rows="3" maxlength="2000" placeholder="optional but speeds up approval"><%= form.note || '' %></textarea></label>
    <button class="btn-primary" type="submit">Submit deal for review →</button>
    <small class="muted">Deals are human-verified. Approved = points in your account. See the <a href="/become-partner" style="color:var(--primary);font-weight:700">partner programme</a>.</small>
  </form>

  <% if (submissions.length) { %>
    <div class="sec-head"><h2>📋 Your submissions</h2></div>
    <div class="sub-list" style="max-width:760px">
      <% submissions.forEach(s => { %>
        <div class="sub-item">
          <div>
            <b><%= s.title %></b>
            <small><%= String(s.created_at).slice(0,10) %><%= s.store_name ? ' · ' + s.store_name : '' %><%= s.admin_note ? ' · ' + s.admin_note : '' %></small>
          </div>
          <span class="sub-status <%= s.status %>"><%= s.status === 'approved' ? `✓ approved · +${s.points} pts` : s.status === 'rejected' ? '✕ rejected' : '⏳ pending' %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
