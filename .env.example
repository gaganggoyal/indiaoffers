# ═══════════════════════════════════════════════════════════════════════════
#  IndiaOffers.in — Environment Configuration
#  Copy this file to .env and fill in real values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=indiaoffers
DB_USER=root
DB_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string

# ── Amazon Associates / PA-API ───────────────────────────────────────────
AMAZON_ASSOCIATE_TAG=indiaoffers-21
AMAZON_PARTNER_TAG=indiaoffers-21
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_REPORTING_EMAIL=

# ── Flipkart Affiliate ────────────────────────────────────────────────────
FLIPKART_AFFILIATE_ID=indiaoffers
FLIPKART_AFFILIATE_KEY=
FLIPKART_TRACKING_ID=indoffers01
FLIPKART_POSTBACK_TOKEN=replace_with_a_long_random_string

# ── Email (for notifications, password reset) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@indiaoffers.in

# ── Payment / Withdrawal Processing (e.g. Razorpay Payouts) ──────────────
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
