# IndiaOffers.in — environment. Copy to .env and fill in. NEVER commit .env.
# In production (NODE_ENV=production) the app refuses to boot until JWT_SECRET
# is set to a real random string (see src/config.js).

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SITE_URL=https://indiaoffers.in

# Signs admin + user session cookies. Generate: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_string

# ── Database ──────────────────────────────────────────────────────────────────
# Production uses managed MySQL. Apply the schema once before first boot:
#   mysql -h <host> -u <user> -p <db> < src/db/schema.mysql.sql
DB_DRIVER=mysql
DB_HOST=your-managed-mysql-host
DB_PORT=3306
DB_NAME=indiaoffers
DB_USER=indiaoffers
DB_PASSWORD=your_mysql_password

# ── First admin (used only by `npm run db:seed`, before the first login) ───────
ADMIN_PASSWORD=set_a_strong_password_before_seeding

# ── Affiliate tags (appended on outbound /go redirects) ────────────────────────
AMAZON_ASSOCIATE_TAG=indiaoffers0c-21
FLIPKART_AFFILIATE_ID=indiaoffers

# ── Quick Add (optional): Gemini cleans/categorises scraped product titles ─────
# Get a key at https://aistudio.google.com/apikey. Without it, Quick Add falls
# back to rule-based title cleanup.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Email alerts (optional) ────────────────────────────────────────────────────
# Without SMTP_HOST the mailer runs in "log" mode (emails printed, not sent).
# Fill these to send real alert emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IndiaOffers <alerts@indiaoffers.in>

# Background delivery of queued alerts. Set to 1 to auto-send on a timer.
ALERTS_AUTO_SEND=0
ALERTS_SEND_INTERVAL_MIN=5
