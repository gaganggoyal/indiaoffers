NODE_ENV=production
PORT=3000
SITE_URL=https://indiaoffers.in

# sqlite (zero-config) or mysql (fill DB_* and run src/db/schema.mysql.sql)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=indiaoffers
DB_USER=root
DB_PASSWORD=

JWT_SECRET=replace_with_long_random_string
ADMIN_PASSWORD=set_before_first_seed

AMAZON_ASSOCIATE_TAG=indiaoffers-21
FLIPKART_AFFILIATE_ID=indiaoffers
