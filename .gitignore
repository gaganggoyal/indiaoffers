# dependencies
node_modules/

# local secrets — never commit
.env

# local dev database (repo-root only — unanchored "data/" also hid src/data/)
/data/

# admin-uploaded images (keep the folder, ignore its contents)
public/uploads/*
!public/uploads/.gitkeep

# OS / editor junk
.DS_Store
Thumbs.db

# logs & test artifacts
*.log
test-results/
